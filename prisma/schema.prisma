  createdBy           String?
  createdAt           DateTime          @default(now())
  workspace           Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  associatedCompany   Company?          @relation(fields: [associatedCompanyId], references: [id], onDelete: SetNull)
  associatedContact   Contact?          @relation(fields: [associatedContactId], references: [id], onDelete: SetNull)

  @@index([workspaceId, platform])
  @@index([workspaceId, active])
}

model SocialPostWatch {
  id          String                  @id @default(cuid())
  workspaceId String
  campaignId  String?
  platform    String
  postUrl     String
  watchReason String
  active      Boolean                 @default(true)
  createdBy   String?
  createdAt   DateTime                @default(now())
  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign    Campaign?               @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  events      SocialEngagementEvent[]
  lead        Lead?                   @relation(fields: [leadId], references: [id])
  leadId      String?

  @@unique([workspaceId, platform, postUrl])
  @@index([workspaceId, active])
}

model SocialEngagementEvent {
  id                String              @id @default(cuid())
  workspaceId       String
  postWatchId       String?
  platform          String
  engagementType    String
  engagerName       String?
  engagerTitle      String?
  engagerCompany    String?
  engagerProfileUrl String?
  sourceUrl         String?
  rawPayload        Json?
  observedAt        DateTime            @default(now())
  idempotencyKey    String
  createdAt         DateTime            @default(now())
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  postWatch         SocialPostWatch?    @relation(fields: [postWatchId], references: [id], onDelete: SetNull)
  matches           SocialSignalMatch[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, platform])
  @@index([workspaceId, observedAt])
}

model SocialSignalMatch {
  id                String                @id @default(cuid())
  workspaceId       String
  eventId           String
