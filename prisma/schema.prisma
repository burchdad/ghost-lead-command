generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  companies              Company[]
  contacts               Contact[]
  leads                  Lead[]
  campaigns              Campaign[]
  sourcingCampaigns      SourcingCampaign[]
  suppressionRecords     SuppressionRecord[]
  waitlistSubmissions    WaitlistSubmission[]
  outreachQueue          OutreachQueueItem[]
  replies                Reply[]
  integrationHealth      IntegrationHealth[]
  proposals              Proposal[]
  agents                 AgentTemplate[]
  prompts                PromptTemplate[]
  automationEvents       AutomationEvent[]
  bookingTasks           BookingTask[]
  sequenceSteps          SequenceStep[]
  onboardingSessions     AIOnboardingSession[]
  launchAgentRuns        LaunchAgentRun[]
  pricingQuotes          PricingQuote[]
  commercialProposals    CommercialProposal[]
  humanReviewTasks       HumanReviewTask[]
  intentSignals          IntentSignal[]
  socialProfileWatches   SocialProfileWatch[]
  socialPostWatches      SocialPostWatch[]
  socialEngagementEvents SocialEngagementEvent[]
  socialSignalMatches    SocialSignalMatch[]
  lookalikeSeeds         LookalikeSeed[]
  lookalikeModelVersions LookalikeModelVersion[]
  localMarketProfiles    LocalMarketProfile[]
  inboundConversations   InboundConversation[]
  qualificationPlaybooks QualificationPlaybook[]
  communicationPolicies  CommunicationPolicy[]
  salesPlaybooks         SalesPlaybook[]
  sourceQualityProfiles  SourceQualityProfile[]
  experimentProposals    ExperimentProposal[]
  agencyMemberships      AgencyMembership[]
  agencyClientWorkspaces AgencyClientWorkspace[]
  intelligenceSnapshots  OpportunityIntelligenceSnapshot[]
}

enum VegaLaunchAgentType {
  VEGA_CONCIERGE
  BUSINESS_DISCOVERY_AGENT
  MARKET_STRATEGY_AGENT
  OFFER_ARCHITECT
  CAMPAIGN_ARCHITECT
  PRODUCT_ADVISOR
  PRICING_AGENT
  PROPOSAL_AGENT
  BILLING_CONCIERGE
  PROVISIONING_AGENT
  LAUNCH_QA_AGENT
}

enum AIOnboardingStatus {
  STARTED
  DISCOVERING_BUSINESS
  RESEARCHING_MARKET
  BUILDING_OFFER
  DESIGNING_CAMPAIGN
  RECOMMENDING_PRODUCT
  PRICING
  REVIEWING_PROPOSAL
  AWAITING_CHECKOUT
  PAYMENT_PROCESSING
  PAID
  PROVISIONING
  LAUNCH_REVIEW
  READY
  LAUNCHED
  ABANDONED
  HUMAN_REVIEW
  BLOCKED
}

enum VegaProductCode {
  VEGA_SCOUT
  VEGA_REACH
  VEGA_CONVERT
  VEGA_MANAGED
  VEGA_WHITE_LABEL
}

enum LaunchReadinessStatus {
  NOT_READY
  READY_FOR_DRY_RUN
  READY_FOR_CUSTOMER_REVIEW
  READY_FOR_LIVE
  BLOCKED
}

enum CommercialProposalStatus {
  DRAFT
  PRESENTED
  REVISION_REQUESTED
  ACCEPTED
  DECLINED
  EXPIRED
  HUMAN_REVIEW
}

enum HumanReviewStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELED
}

enum IntelligenceSnapshotType {
  QUALIFICATION
  SIGNAL_UPDATE
  DECISION
  PRE_EXECUTION
  DELIVERY_EVENT
  ENGAGEMENT_EVENT
  REPLY
  CALL_OUTCOME
  MEETING_EVENT
  MANUAL_OVERRIDE
  POLICY_CHANGE
  OUTCOME
}

model Company {
  id                     String                  @id @default(cuid())
  workspaceId            String
  name                   String
  niche                  String
  website                String?
  domain                 String?
  crmSource              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts               Contact[]
  leads                  Lead[]
  opportunities          Opportunity[]
  intentSignals          IntentSignal[]
  socialProfileWatches   SocialProfileWatch[]
  localMarketProfiles    LocalMarketProfile[]
  inboundConversations   InboundConversation[]
  qualificationPlaybooks QualificationPlaybook[]
  communicationPolicies  CommunicationPolicy[]
  salesPlaybooks         SalesPlaybook[]
  sourceQualityProfiles  SourceQualityProfile[]
  experimentProposals    ExperimentProposal[]

  @@index([workspaceId])
  @@index([domain])
}

model Contact {
  id                   String                @id @default(cuid())
  workspaceId          String
  companyId            String?
  name                 String
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  role                 String?
  title                String?
  source               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company              Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leads                Lead[]
  interactions         Interaction[]
  intentSignals        IntentSignal[]
  socialProfileWatches SocialProfileWatch[]
  inboundConversations InboundConversation[]

  @@index([workspaceId])
  @@index([companyId])
}

model Lead {
  id                   String                @id @default(cuid())
  workspaceId          String
  companyId            String?
  contactId            String?
  name                 String
  title                String?
  description          String?
  companyName          String
  niche                String
  stage                String
  priority             String?
  score                Int                   @default(0)
  leadScore            Int?
  value                Int                   @default(0)
  source               String
  lastTouch            String
  nextAction           String
  tags                 Json?
  customFields         Json?
  crmSyncStatus        String                @default("pending")
  crmSyncedAt          DateTime?
  status               String                @default("active")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company              Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact              Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunities        Opportunity[]
  interactions         Interaction[]
  outreachQueue        OutreachQueueItem[]
  replies              Reply[]
  automationEvents     AutomationEvent[]
  bookingTasks         BookingTask[]
  sequenceSteps        SequenceStep[]
  intentSignals        IntentSignal[]
  socialPostWatches    SocialPostWatch[]
  socialSignalMatches  SocialSignalMatch[]
  inboundConversations InboundConversation[]
  inboundMessages      InboundMessage[]
  lookalikeSeeds       LookalikeSeed[]
  intelligenceSnapshots OpportunityIntelligenceSnapshot[]

  @@index([workspaceId])
  @@index([stage])
  @@index([score])
  @@index([crmSyncStatus])
}

model OpportunityIntelligenceSnapshot {
  id                           String    @id @default(cuid())
  workspaceId                  String
  campaignId                   String?
  leadId                       String
  companyId                    String?
  contactId                    String?
  intelligenceVersion          String
  policyVersion                String
  leadScore                    Int
  intentScore                  Int
  trustScore                   Int
  contactConfidence            Int
  sourceQuality                Int
  messageQuality               Int?
  campaignFit                  Int
  senderHealth                 Int
  conversationProbability      Float?
  meetingProbability           Float?
  closeProbability             Float?
  bounceProbability            Float?
  recommendedChannel           String
  recommendedAction            String
  decisionLane                 String
  overallConfidence            Int
  snapshotType                 IntelligenceSnapshotType @default(DECISION)
  explanation                  Json
  evidence                     Json
  blockers                     Json
  triggerType                  String
  triggerId                    String?
  createdAt                    DateTime  @default(now())
  workspace                    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead                         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([workspaceId, leadId, createdAt])
  @@index([workspaceId, campaignId, createdAt])
  @@index([workspaceId, snapshotType, createdAt])
}

model Opportunity {
  id          String     @id @default(cuid())
  companyId   String
  leadId      String?
  title       String
  stage       String
  value       Int
  probability Int        @default(50)
  closeDate   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead        Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  proposals   Proposal[]

  @@index([companyId])
  @@index([leadId])
}

model Interaction {
  id             String   @id @default(cuid())
  leadId         String?
  contactId      String?
  channel        String
  direction      String
  body           String
  classification String?
  metadata       Json?
  createdAt      DateTime @default(now())
  lead           Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact        Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([contactId])
}

model WaitlistSubmission {
  id           String    @id @default(cuid())
  workspaceId  String
  email        String
  payload      Json
  status       String    @default("received")
  crmContactId String?
  crmLeadId    String?
  error        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  syncedAt     DateTime?
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([status])
}

model Campaign {
  id                     String                  @id @default(cuid())
  workspaceId            String
  name                   String
  mode                   String
  audience               String
  status                 String
  replyTarget            Float
  bookingTarget          Float
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  workspace              Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps                  CampaignStep[]
  intentSignals          IntentSignal[]
  socialPostWatches      SocialPostWatch[]
  localMarketProfiles    LocalMarketProfile[]
  inboundConversations   InboundConversation[]
  qualificationPlaybooks QualificationPlaybook[]
  communicationPolicies  CommunicationPolicy[]
  salesPlaybooks         SalesPlaybook[]
  sourceQualityProfiles  SourceQualityProfile[]
  experimentProposals    ExperimentProposal[]

  @@index([workspaceId])
}

model CampaignStep {
  id         String   @id @default(cuid())
  campaignId String
  dayOffset  Int
  channel    String
  body       String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model SourcingCampaign {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  provider       String
  query          String
  location       String?
  industries     String?
  titles         String?
  dailyLimit     Int       @default(25)
  scoreThreshold Int       @default(70)
  status         String    @default("draft")
  lastRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
}

model SuppressionRecord {
  id          String    @id @default(cuid())
  workspaceId String
  type        String
  value       String
  reason      String
  source      String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type, value])
  @@index([workspaceId])
}

model OutreachQueueItem {
  id           String    @id @default(cuid())
  workspaceId  String
  leadId       String?
  channel      String
  provider     String
  subject      String?
  body         String
  status       String    @default("pending")
  reason       String?
  scheduledFor DateTime?
  approvedAt   DateTime?
  sentAt       DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
}

model Reply {
  id             String    @id @default(cuid())
  workspaceId    String
  leadId         String?
  channel        String
  from           String
  body           String
  classification String
  source         String
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([classification])
}

model IntegrationHealth {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  status      String
  detail      String
  checkedAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Proposal {
  id            String       @id @default(cuid())
  workspaceId   String
  opportunityId String?
  title         String
  status        String
  setupFee      Int
  monthlyFee    Int
  revSharePct   Float
  summary       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([opportunityId])
}

model AgentTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  source      String
  useCase     String
  price       String
  demoScript  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model PromptTemplate {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  body        String
  category    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AutomationEvent {
  id          String    @id @default(cuid())
  workspaceId String
  leadId      String?
  title       String
  detail      String
  status      String
  type        String    @default("system")
  payload     Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
  @@index([type])
}

model BookingTask {
  id               String    @id @default(cuid())
  workspaceId      String
  leadId           String?
  ownerEmail       String?
  status           String    @default("blocked")
  meetingTitle     String
  meetingLink      String?
  calendarProvider String?
  durationMinutes  Int       @default(30)
  scheduledFor     DateTime?
  prepNotes        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
}

model SequenceStep {
  id           String    @id @default(cuid())
  workspaceId  String
  leadId       String?
  stepNumber   Int
  dayOffset    Int
  channel      String
  provider     String?
  subject      String?
  body         String
  status       String    @default("draft")
  scheduledFor DateTime?
  approvedAt   DateTime?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead         Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([leadId])
  @@index([status])
}

model AIOnboardingSession {
  id                      String                @id @default(cuid())
  workspaceId             String?
  visitorId               String?
  authenticatedUserId     String?
  status                  AIOnboardingStatus    @default(STARTED)
  currentObjective        String?
  currentAgent            VegaLaunchAgentType   @default(VEGA_CONCIERGE)
  collectedFacts          Json?
  confirmedFacts          Json?
  inferredFacts           Json?
  missingRequiredFacts    Json?
  rejectedRecommendations Json?
  businessProfileDraft    Json?
  targetMarketDraft       Json?
  offerDraft              Json?
  campaignDraft           Json?
  productRecommendation   Json?
  pricingQuoteId          String?
  proposalId              String?
  checkoutSessionId       String?
  subscriptionId          String?
  provisioningStatus      String?
  launchReadiness         LaunchReadinessStatus @default(NOT_READY)
  lastActivityAt          DateTime              @default(now())
  expiresAt               DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  workspace               Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  messages                AIOnboardingMessage[]
  launchAgentRuns         LaunchAgentRun[]
  pricingQuotes           PricingQuote[]
  commercialProposals     CommercialProposal[]
  humanReviewTasks        HumanReviewTask[]

  @@index([workspaceId])
  @@index([status])
  @@index([visitorId])
  @@index([lastActivityAt])
}

model AIOnboardingMessage {
  id                String               @id @default(cuid())
  sessionId         String
  role              String
  content           String
  structuredParts   Json?
  visibleToCustomer Boolean              @default(true)
  agentType         VegaLaunchAgentType?
  createdAt         DateTime             @default(now())
  session           AIOnboardingSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([agentType])
}

model LaunchAgentRun {
  id                  String              @id @default(cuid())
  workspaceId         String?
  onboardingSessionId String
  agentType           VegaLaunchAgentType
  status              String
  input               Json
  structuredOutput    Json?
  promptVersion       String
  model               String
  confidence          Float?
  cost                Float?
  startedAt           DateTime            @default(now())
  completedAt         DateTime?
  error               String?
  createdAt           DateTime            @default(now())
  workspace           Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  onboardingSession   AIOnboardingSession @relation(fields: [onboardingSessionId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([onboardingSessionId])
  @@index([agentType])
  @@index([status])
}

model PricingQuote {
  id                  String               @id @default(cuid())
  workspaceId         String?
  onboardingSessionId String
  productCode         VegaProductCode
  inputConfiguration  Json
  lineItems           Json
  totals              Json
  authorizedDiscounts Json?
  priceVersion        String
  createdAt           DateTime             @default(now())
  expiresAt           DateTime
  acceptedAt          DateTime?
  workspace           Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  onboardingSession   AIOnboardingSession  @relation(fields: [onboardingSessionId], references: [id], onDelete: Cascade)
  commercialProposals CommercialProposal[]

  @@index([workspaceId])
  @@index([onboardingSessionId])
  @@index([productCode])
  @@index([expiresAt])
}

model CommercialProposal {
  id                       String                   @id @default(cuid())
  onboardingSessionId      String
  workspaceId              String?
  version                  Int
  productCode              VegaProductCode
  fulfillmentMode          String
  campaignSummary          Json
  targetMarket             Json
  territory                Json
  offer                    Json
  vegaResponsibilities     Json
  customerResponsibilities Json
  allowances               Json
  setupScope               Json
  recurringScope           Json
  billingSummary           Json
  limitations              Json
  termsReference           String
  pricingQuoteId           String
  status                   CommercialProposalStatus @default(DRAFT)
  approvedAt               DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  workspace                Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  onboardingSession        AIOnboardingSession      @relation(fields: [onboardingSessionId], references: [id], onDelete: Cascade)
  pricingQuote             PricingQuote             @relation(fields: [pricingQuoteId], references: [id], onDelete: Restrict)

  @@unique([onboardingSessionId, version])
  @@index([workspaceId])
  @@index([pricingQuoteId])
  @@index([status])
}

model HumanReviewTask {
  id                  String               @id @default(cuid())
  workspaceId         String?
  onboardingSessionId String?
  reason              String
  status              HumanReviewStatus    @default(OPEN)
  priority            String               @default("normal")
  payload             Json?
  resolution          Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workspace           Workspace?           @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  onboardingSession   AIOnboardingSession? @relation(fields: [onboardingSessionId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([onboardingSessionId])
  @@index([status])
}

enum IntentSignalType {
  WEBSITE_VISIT
  FORM_SUBMISSION
  CONTENT_DOWNLOAD
  EMAIL_OPEN
  EMAIL_CLICK
  EMAIL_REPLY
  REPEAT_EMAIL_ENGAGEMENT
  LINKEDIN_REACTION
  LINKEDIN_COMMENT
  LINKEDIN_SHARE
  LINKEDIN_PROFILE_ENGAGEMENT
  LINKEDIN_REPEAT_ENGAGEMENT
  COMPETITOR_ENGAGEMENT
  SOCIAL_MENTION
  SOCIAL_FOLLOW
  JOB_CHANGE
  LEADERSHIP_CHANGE
  COMPANY_HIRING
  FUNDING_EVENT
  LOCATION_EXPANSION
  NEW_SERVICE_LAUNCH
  TECHNOLOGY_CHANGE
  NEGATIVE_REVIEW_PATTERN
  MISSED_CALL_REVIEW_SIGNAL
  SCHEDULING_COMPLAINT
  SLOW_RESPONSE_COMPLAINT
  WEBSITE_CONVERSION_GAP
  WEBSITE_FORM_FAILURE
  SEARCH_VISIBILITY_GAP
  GOOGLE_PROFILE_GAP
  CRM_REACTIVATION_SIGNAL
  PREVIOUS_OPPORTUNITY_REOPENED
  REFERRAL_SIGNAL
  MANUAL_OPERATOR_SIGNAL
  THIRD_PARTY_INTENT_SIGNAL
}

enum VegaCapabilityGroup {
  VEGA_DISCOVER
  VEGA_SIGNAL
  VEGA_REACH
  VEGA_ENGAGE
  VEGA_CONVERT
  VEGA_INTELLIGENCE
}

enum SocialProfileType {
  CUSTOMER_TEAM_MEMBER
  COMPETITOR
  PARTNER
  INDUSTRY_INFLUENCER
  TARGET_ACCOUNT
  INVESTOR
  CUSTOM
}

enum SocialSignalTier {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum NextBestChannel {
  AUTO_EMAIL
  APPROVAL_EMAIL
  CALL_FIRST
  PHONE_ASSIST_AFTER_EMAIL
  WEBSITE_CONTACT_FORM
  LINKEDIN_MANUAL_TASK
  SOCIAL_RESPONSE_TASK
  SMS_INBOUND_ONLY
  SMS_FOLLOW_UP
  CHAT_ENGAGEMENT
  WHATSAPP_INBOUND
  RESEARCH_MORE
  NURTURE
  SUPPRESS
  NO_ACTION
}

enum InboundConversationStatus {
  OPEN
  AI_ACTIVE
  HUMAN_TAKEOVER
  QUALIFIED
  BOOKING_OFFERED
  BOOKED
  CLOSED
  SUPPRESSED
}

enum ReplyCategory {
  POSITIVE_INTEREST
  PRICING_REQUEST
  MEETING_REQUEST
  INFORMATION_REQUEST
  QUALIFICATION_ANSWER
  REFERRAL
  CORRECT_CONTACT
  OBJECTION
  NOT_NOW
  NURTURE
  NOT_INTERESTED
  WRONG_PERSON
  UNSUBSCRIBE
  STOP
  OUT_OF_OFFICE
  SPAM
  UNKNOWN
}

enum ConversationPolicyMode {
  DRAFT_ONLY
  HUMAN_APPROVAL
  CONTROLLED_AUTO_REPLY
  HUMAN_TAKEOVER
}

enum DeliverabilityState {
  HEALTHY
  CAUTION
  RESTRICTED
  STOP
}

enum ExperimentStatus {
  DRAFT
  PROPOSED
  APPROVED
  REJECTED
  RUNNING
  PAUSED
  COMPLETED
  INCONCLUSIVE
  ROLLED_BACK
}

model IntentSignal {
  id                String           @id @default(cuid())
  workspaceId       String
  campaignId        String?
  leadId            String?
  companyId         String?
  contactId         String?
  signalType        IntentSignalType
  sourceProvider    String
  sourceRecordId    String?
  sourceUrl         String?
  observedAt        DateTime         @default(now())
  expiresAt         DateTime?
  rawPayload        Json?
  normalizedPayload Json?
  summary           String
  confidence        Float            @default(0)
  intentStrength    Float            @default(0)
  scoreImpact       Int              @default(0)
  accountLevel      Boolean          @default(false)
  personLevel       Boolean          @default(false)
  verified          Boolean          @default(false)
  evidence          Json?
  idempotencyKey    String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign          Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead              Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact           Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, signalType])
  @@index([workspaceId, observedAt])
  @@index([leadId])
  @@index([companyId])
  @@index([contactId])
}

model SocialProfileWatch {
  id                  String            @id @default(cuid())
  workspaceId         String
  platform            String
  profileUrl          String
  profileType         SocialProfileType
  watchReason         String
  associatedCompanyId String?
  associatedContactId String?
